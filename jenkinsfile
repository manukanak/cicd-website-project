pipeline {
agent any

stages {

    stage('Checkout') {
        steps {
            echo 'Source Code Downloaded'
        }
    }

    stage('Build') {
        steps {
            echo 'Build Successful'
        }
    }

    stage('Deploy') {
        steps {
            sh '''
            sudo cp index.html /var/www/html/index.html
            '''
        }
    }

    stage('Verify') {
        steps {
            sh '''
            ls -l /var/www/html/
        }
    }
}

}
